# This file is a minimal local sample.
# See README.md / README.en.md for the full list of runtime knobs.

# ===== Azure Foundry Project =====
AZURE_AI_PROJECT_ENDPOINT=https://aif-ch-cht-ccoe-ai-agent.services.ai.azure.com/api/projects/ArchitectAgent
MODEL_DEPLOYMENT=gpt-5.4
GITHUB_COPILOT_MODEL=gpt-5.4

# ===== Agent Names (same Foundry Project) =====
ARCHITECTURE_AGENT_NAME=Azure-Architecture-Clarification-Agent
TERRAFORM_AGENT_NAME=Azure-Terraform-Generation-Agent
DIAGRAM_AGENT_NAME=Azure-Diagram-Generation-Agent
PRICING_STRUCTURE_AGENT_NAME=Azure-Pricing-Structure-Agent
PRICING_BROWSER_AGENT_NAME=Azure-Pricing-Browser-Agent

# ===== Timeouts (seconds) =====
# Foundry base timeout / retry knobs
AGENT_MAX_RETRIES=2
AGENT_RETRY_DELAY=5.0
AGENT_TIMEOUT=360

# Diagram/Terraform agent 生成複雜 IaC + 圖表時間較長，建議 300s+
DIAGRAM_AGENT_TIMEOUT=360
TERRAFORM_AGENT_TIMEOUT=360
COST_STRUCTURE_AGENT_TIMEOUT=300
COST_BROWSER_AGENT_TIMEOUT=600

# Local Copilot provider health / retry knobs
GITHUB_COPILOT_TIMEOUT=1200
GITHUB_COPILOT_PROGRESS_TIMEOUT=180
GITHUB_COPILOT_MAX_RESTARTS=1
GITHUB_COPILOT_RETRY_DELAY=2.0
GITHUB_COPILOT_STARTUP_PREFLIGHT=true
GITHUB_COPILOT_WORKDIR=./out

# ===== Output =====
OUTPUT_DIR=./out

# ===== Mode =====
# true  → 使用 mock agents（離線測試，無需 Azure 連線）
# false → 使用真實 Foundry agents
MOCK_MODE=true

# ===== Run Mode =====
# server → 啟動 HTTP server (port 8088)
# cli    → 直接從 stdin/argv 執行 workflow
RUN_MODE=server

# ===== Pricing =====
# ORCHESTRATOR_ALLOW_OUTPUT_DIR_OVERRIDE=true
PRICING_EXECUTION_MODE=retail_api

# ===== Azure Foundry Project =====
AZURE_AI_PROJECT_ENDPOINT=https://aif-ch-cht-ccoe-ai-agent.services.ai.azure.com/api/projects/ArchitectAgent
MODEL_DEPLOYMENT=gpt-5.2

# ===== Agent Names (same Foundry Project) =====
CLARIFICATION_AGENT_NAME=Architecture-Clarification-Agent
TERRAFORM_AGENT_NAME=Azure-Terraform-Architect-Agent
DIAGRAM_AGENT_NAME=DaC-Dagrams-Mingrammer
COST_AGENT_NAME=Agent-AzureCalculator

# ===== Timeouts (seconds) =====
# Diagram/Terraform agent 生成複雜 IaC + 圖表時間較長，建議 300s+
AGENT_TIMEOUT=300
DIAGRAM_AGENT_TIMEOUT=300
TERRAFORM_AGENT_TIMEOUT=300

# ===== Output =====
OUTPUT_DIR=./out

# ===== Mode =====
# true  → 使用 mock agents（離線測試，無需 Azure 連線）
# false → 使用真實 Foundry agents
MOCK_MODE=true

# ===== Run Mode =====
# server → 啟動 HTTP server (port 8088)
# cli    → 直接從 stdin/argv 執行 workflow
RUN_MODE=server
